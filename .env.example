# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับ environment ของคุณ
# cp .env.example .env

# Backend Go server URL (dev proxy target)
VITE_BACKEND_URL=http://localhost:8080

# WebRTC STUN server
VITE_STUN_URL=stun:stun.l.google.com:19302

# WebRTC TURN server (optional — ใส่ถ้ามี TURN server ของตัวเอง)
# VITE_TURN_URL=turn:turn.example.com:3478
# VITE_TURN_USER=username
# VITE_TURN_CRED=password
